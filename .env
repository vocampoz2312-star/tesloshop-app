# ─────────────────────────────────────────────
# Cómo usar este archivo:
#   cp .env.example .env
# Luego edita los valores marcados como "cambiar".
# NUNCA subas .env al repositorio (está en .gitignore).
# ─────────────────────────────────────────────
# ─────── PostgreSQL ───────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=una_contrasena_segura
POSTGRES_DB=TesloDB
POSTGRES_PUBLISH_PORT=5432
POSTGRES_CONTAINER_NAME=teslo-db

# ─────── Backend (NestJS) ─────────────────────
# DB_* debe coincidir exactamente con PostgreSQL
APP_VERSION=1.0.1
STAGE=dev
DB_HOST=db               # <- nombre del servicio Postgres en Compose
DB_PORT=5432
DB_USERNAME=postgres     # <- igual que POSTGRES_USER
DB_PASSWORD=una_contrasena_segura    # <- igual que POSTGRES_PASSWORD
DB_NAME=TesloDB          # <- igual que POSTGRES_DB
PORT=3000
BACKEND_PUBLISH_PORT=3000
BACKEND_CONTAINER_NAME=teslo-backend
HOST_API=http://localhost:3000/api
JWT_SECRET=una_cadena_larga_y_aleatoria

# ─────── Frontend (Nginx) ─────────────────────
FRONTEND_PUBLISH_PORT=80
FRONTEND_CONTAINER_NAME=teslo-frontend